<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Days of the Apocalypse</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none;
        }
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #050508;
            font-family: 'Courier New', Courier, monospace;
        }
        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, #1a0f1a, #0d0d13, #151522);
        }
        /* Apocalyptic Environment Elements */
        .skyline {
            position: absolute;
            bottom: 30%;
            width: 200%;
            height: 40%;
            background: repeating-linear-gradient(90deg, #111 0px, #111 40px, transparent 40px, transparent 80px);
            opacity: 0.3;
            mask-image: linear-gradient(to top, black 20%, transparent 100%);
            -webkit-mask-image: linear-gradient(to top, black 20%, transparent 100%);
            animation: parallax 20s linear infinite;
        }
        .fog {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 50%;
            background: linear-gradient(to top, rgba(223, 76, 31, 0.15), transparent);
            pointer-events: none;
        }
        .ground {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 35%;
            background: #09090d;
            border-top: 4px solid #df4c1f;
            box-shadow: 0 0 20px rgba(223, 76, 31, 0.4);
        }
        /* 2D Animated Man-Transformed-Robot Character Structure */
        #cyborg {
            position: absolute;
            bottom: 25%;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 180px;
            z-index: 10;
        }
        /* Organic Human Parts (Left Side Asset Look) */
        .human-head {
            position: absolute;
            top: 5px;
            left: 30px;
            width: 32px;
            height: 35px;
            background-color: #d9a082;
            border-radius: 40% 50% 30% 40%;
        }
        .human-hair {
            position: absolute;
            top: -3px;
            left: 28px;
            width: 30px;
            height: 18px;
            background-color: #2b1d1d;
            border-radius: 50% 40% 0 0;
        }
        .human-torso {
            position: absolute;
            top: 40px;
            left: 30px;
            width: 32px;
            height: 65px;
            background-color: #3b444b;
            border-radius: 10px 0 0 10px;
        }
        .human-arm {
            position: absolute;
            top: 42px;
            left: 15px;
            width: 20px;
            height: 55px;
            background-color: #3b444b;
            border-radius: 8px;
            transform-origin: top center;
            animation: humanSwing 1.5s ease-in-out infinite alternate;
        }
        .human-hand {
            position: absolute;
            bottom: -8px;
            left: 2px;
            width: 16px;
            height: 16px;
            background-color: #d9a082;
            border-radius: 50%;
        }
        .human-leg {
            position: absolute;
            top: 100px;
            left: 32px;
            width: 24px;
            height: 65px;
            background-color: #25282a;
            border-radius: 5px;
            transform-origin: top center;
            animation: legMoveLeft 1.2s linear infinite;
        }
        /* Mechanical Robot Parts (Right Side Mechanical Integration) */
        .robot-head-half {
            position: absolute;
            top: 3px;
            left: 58px;
            width: 32px;
            height: 37px;
            background-color: #5a6577;
            border-radius: 20% 40% 40% 20%;
            border-left: 2px solid #00ffcc;
        }
        .laser-eye {
            position: absolute;
            top: 12px;
            right: 6px;
            width: 10px;
            height: 6px;
            background-color: #00ffcc;
            border-radius: 2px;
            box-shadow: 0 0 12px #00ffcc, 0 0 20px #00ffcc;
        }
        .laser-beam {
            position: absolute;
            top: 14px;
            left: 85px;
            width: 150px;
            height: 2px;
            background: linear-gradient(to right, rgba(0, 255, 204, 1), transparent);
            pointer-events: none;
            opacity: 0.7;
            animation: flicker 0.2s infinite;
        }
        .robot-torso {
            position: absolute;
            top: 38px;
            left: 60px;
            width: 35px;
            height: 67px;
            background: linear-gradient(135deg, #424b5a, #2c323e);
            border-radius: 0 12px 12px 0;
            border-right: 3px solid #7888a3;
        }
        .power-core {
            position: absolute;
            top: 20px;
            left: -5px;
            width: 14px;
            height: 25px;
            background-color: #00ffcc;
            border-radius: 4px;
            box-shadow: 0 0 15px #00ffcc;
            animation: pulse 1s infinite alternate;
            z-index: 5;
        }
        .robot-arm {
            position: absolute;
            top: 40px;
            left: 88px;
            width: 24px;
            height: 60px;
            background-color: #2c323e;
            border: 2px solid #5a6577;
            border-radius: 10px;
            transform-origin: top center;
            animation: robotSwing 1.5s ease-in-out infinite alternate;
        }
        .plasma-cannon {
            position: absolute;
            bottom: -15px;
            left: -4px;
            width: 32px;
            height: 24px;
            background-color: #1a1d24;
            border: 2px solid #00ffcc;
            border-radius: 4px;
        }
        .cannon-glow {
            position: absolute;
            right: -4px;
            top: 4px;
            width: 8px;
            height: 12px;
            background-color: #00ffcc;
            box-shadow: 0 0 10px #00ffcc;
        }
        .robot-leg {
            position: absolute;
            top: 100px;
            left: 66px;
            width: 26px;
            height: 68px;
            background-color: #424b5a;
            border: 2px solid #2c323e;
            border-radius: 6px;
            transform-origin: top center;
            animation: legMoveRight 1.2s linear infinite;
        }
        /* Interface HUD overlays */
        .hud {
            position: absolute;
            top: 30px;
            left: 30px;
            color: #00ffcc;
            text-shadow: 0 0 8px rgba(0, 255, 204, 0.6);
            font-size: 14px;
            line-height: 1.6;
            pointer-events: none;
        }
        .title {
            position: absolute;
            top: 30px;
            right: 30px;
            color: #df4c1f;
            font-size: 20px;
            font-weight: bold;
            text-shadow: 0 0 10px rgba(223, 76, 31, 0.5);
            letter-spacing: 2px;
        }
        /* Core Animations */
        @keyframes legMoveLeft {
            0% { transform: rotate(20deg); }
            50% { transform: rotate(-20deg); }
            100% { transform: rotate(20deg); }
        }
        @keyframes legMoveRight {
            0% { transform: rotate(-20deg); }
            50% { transform: rotate(20deg); }
            100% { transform: rotate(-20deg); }
        }
        @keyframes humanSwing {
            0% { transform: rotate(-10deg); }
            100% { transform: rotate(15deg); }
        }
        @keyframes robotSwing {
            0% { transform: rotate(15deg); }
            100% { transform: rotate(-10deg); }
        }
        @keyframes pulse {
            0% { opacity: 0.4; }
            100% { opacity: 1; }
        }
        @keyframes flicker {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 0.9; }
        }
        @keyframes parallax {
            from { background-position: 0px 0; }
            to { background-position: -1000px 0; }
        }
    </style>
</head>
<body>

    <div id="game-container">
        <!-- Background Scenery Layer -->
        <div class="skyline"></div>
        <div class="fog"></div>
        <div class="ground"></div>

        <!-- System HUD Overlay -->
        <div class="hud">
            SYSTEM: REBOOTING...<br>
            HUMANITY RETENTION: 50%<br>
            CYBERNETIC CORES: ACTIVE<br>
            OBJECTIVE: SURVIVE THE WASTELAND
        </div>
        <div class="title">DAYS OF THE APOCALYPSE</div>

        <!-- Composite Cyborg Character Split View -->
        <div id="cyborg">
            <!-- Left Side / Biological -->
            <div class="human-hair"></div>
            <div class="human-head"></div>
            <div class="human-torso"></div>
            <div class="human-arm">
                <div class="human-hand"></div>
            </div>
            <div class="human-leg"></div>

            <!-- Right Side / Mechanical -->
            <div class="robot-head-half">
                <div class="laser-eye"></div>
            </div>
            <div class="laser-beam"></div>
            <div class="robot-torso">
                <div class="power-core"></div>
            </div>
            <div class="robot-arm">
                <div class="plasma-cannon">
                    <div class="cannon-glow"></div>
                </div>
            </div>
            <div class="robot-leg"></div>
        </div>
    </div>

</body>
</html>
